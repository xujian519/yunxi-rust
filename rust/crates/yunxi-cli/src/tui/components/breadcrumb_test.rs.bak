#[cfg(test)]
mod tests {
    use super::*;
    use crate::tui::components::*;
    use crate::tui::core::action::Action;
    use crate::tui::core::action::ActionResult;
    use crate::tui::core::event::{Event, InputEvent};
    use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};
    use ratatui::backend::TestBackend;
    use ratatui::Terminal;

    #[test]
    fn test_breadcrumb_creation() {
        let breadcrumb = Breadcrumb::new();
        assert!(!breadcrumb.get_state().disabled);
        assert!(!breadcrumb.get_state().focused);
        assert_eq!(breadcrumb.get_state().id.starts_with("breadcrumb_"), true);
    }

    #[test]
    fn test_breadcrumb_with_items() {
        let items = vec![
            BreadcrumbItem {
                label: "Home".to_string(),
                value: Some("/home".to_string()),
                action: Some(Action::Navigate("/home".to_string())),
                disabled: false,
            },
            BreadcrumbItem {
                label: "Documents".to_string(),
                value: Some("/home/documents".to_string()),
                action: Some(Action::Navigate("/documents".to_string())),
                disabled: false,
            },
        ];

        let breadcrumb = Breadcrumb::new().with_items(items);
        assert_eq!(breadcrumb.get_active_item().unwrap().label, "Documents");
    }

    #[test]
    fn test_breadcrumb_navigation() {
        let items = vec![
            BreadcrumbItem {
                label: "Item 1".to_string(),
                value: Some("1".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Item 2".to_string(),
                value: Some("2".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let mut breadcrumb = Breadcrumb::new().with_items(items);
        breadcrumb.prev_item();
        assert_eq!(breadcrumb.get_active_item().unwrap().label, "Item 1");

        breadcrumb.next_item();
        assert_eq!(breadcrumb.get_active_item().unwrap().label, "Item 2");
    }

    #[test]
    fn test_breadcrumb_get_path() {
        let items = vec![
            BreadcrumbItem {
                label: "Home".to_string(),
                value: Some("home".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Documents".to_string(),
                value: Some("docs".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let breadcrumb = Breadcrumb::new().with_items(items);
        assert_eq!(breadcrumb.get_path(), "home / docs");
    }

    #[test]
    fn test_breadcrumb_custom_separator() {
        let items = vec![
            BreadcrumbItem {
                label: "Home".to_string(),
                value: Some("home".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Documents".to_string(),
                value: Some("docs".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let breadcrumb = Breadcrumb::new()
            .with_items(items)
            .with_separator(" > ");
        assert_eq!(breadcrumb.get_path(), "home > docs");
    }

    #[test]
    fn test_breadcrumb_truncate() {
        let items = vec![
            BreadcrumbItem {
                label: "1".to_string(),
                value: Some("1".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "2".to_string(),
                value: Some("2".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "3".to_string(),
                value: Some("3".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "4".to_string(),
                value: Some("4".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "5".to_string(),
                value: Some("5".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let breadcrumb = Breadcrumb::new().with_items(items);
        let display_items = breadcrumb.get_display_items(20);
        assert!(display_items.len() <= 5);
    }

    #[test]
    fn test_breadcrumb_render() {
        let items = vec![
            BreadcrumbItem {
                label: "Home".to_string(),
                value: Some("home".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Documents".to_string(),
                value: Some("docs".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let breadcrumb = Breadcrumb::new().with_items(items);
        let backend = TestBackend::new(40, 5);
        let mut terminal = Terminal::new(backend).unwrap();

        terminal
            .draw(|f| {
                breadcrumb.render(f.area(), f.buffer_mut());
            })
            .unwrap();
    }

    #[test]
    fn test_breadcrumb_home_end() {
        let items = vec![
            BreadcrumbItem {
                label: "Item 1".to_string(),
                value: Some("1".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Item 2".to_string(),
                value: Some("2".to_string()),
                action: None,
                disabled: false,
            },
            BreadcrumbItem {
                label: "Item 3".to_string(),
                value: Some("3".to_string()),
                action: None,
                disabled: false,
            },
        ];

        let mut breadcrumb = Breadcrumb::new().with_items(items);
        breadcrumb.set_active_index(2);

        breadcrumb.on_focus(true);
        let event = Event::Input(InputEvent::Key(KeyEvent::new(KeyCode::Home, KeyModifiers::NONE)));
        breadcrumb.handle_event(&event);
        assert_eq!(breadcrumb.get_active_item().unwrap().label, "Item 1");

        let event = Event::Input(InputEvent::Key(KeyEvent::new(KeyCode::End, KeyModifiers::NONE)));
        breadcrumb.handle_event(&event);
        assert_eq!(breadcrumb.get_active_item().unwrap().label, "Item 3");
    }
}