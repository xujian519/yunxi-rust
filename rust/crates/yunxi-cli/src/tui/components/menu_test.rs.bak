#[cfg(test)]
mod tests {
    use super::*;
    use crate::tui::components::*;
    use crate::tui::core::action::Action;
    use crate::tui::core::action::ActionResult;
    use crate::tui::core::event::{Event, InputEvent};
    use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};
    use ratatui::backend::TestBackend;
    use ratatui::Terminal;

    #[test]
    fn test_menu_creation() {
        let menu = Menu::new();
        assert!(!menu.get_state().disabled);
        assert!(!menu.get_state().focused);
        assert_eq!(menu.get_state().id.starts_with("menu_"), true);
        assert!(!menu.visible);
    }

    #[test]
    fn test_menu_item_builder() {
        let item = MenuItem::action("Open")
            .with_shortcut("Ctrl+O")
            .with_action(Action::Navigate("/open".to_string()));

        assert_eq!(item.label, "Open");
        assert_eq!(item.shortcut, Some("Ctrl+O".to_string()));
        assert!(item.action.is_some());
    }

    #[test]
    fn test_menu_separator() {
        let item = MenuItem::separator();
        assert!(matches!(item.item_type, MenuItemType::Separator));
    }

    #[test]
    fn test_menu_submenu() {
        let submenu_items = vec![MenuItem::action("Sub 1")];
        let item = MenuItem::submenu("File", submenu_items);

        assert_eq!(item.label, "File");
        assert!(matches!(item.item_type, MenuItemType::Submenu(_)));
        assert_eq!(item.children.len(), 1);
    }

    #[test]
    fn test_menu_show_hide() {
        let items = vec![
            MenuItem::action("Item 1").with_action(Action::Navigate("/item1".to_string())),
            MenuItem::action("Item 2").with_action(Action::Navigate("/item2".to_string())),
        ];

        let mut menu = Menu::new().with_items(items);
        assert!(!menu.visible);

        menu.show();
        assert!(menu.visible);

        menu.hide();
        assert!(!menu.visible);
    }

    #[test]
    fn test_menu_navigation() {
        let items = vec![
            MenuItem::action("Item 1"),
            MenuItem::action("Item 2"),
            MenuItem::separator(),
            MenuItem::action("Item 3"),
        ];

        let mut menu = Menu::new().with_items(items);
        menu.next_item();
        assert_eq!(menu.get_active_item().unwrap().label, "Item 2");

        menu.prev_item();
        assert_eq!(menu.get_active_item().unwrap().label, "Item 1");
    }

    #[test]
    fn test_menu_skip_separator() {
        let items = vec![
            MenuItem::action("Item 1"),
            MenuItem::separator(),
            MenuItem::action("Item 2"),
        ];

        let mut menu = Menu::new().with_items(items);
        menu.next_item();
        assert_eq!(menu.get_active_item().unwrap().label, "Item 2");
    }

    #[test]
    fn test_menu_is_submenu() {
        let items = vec![
            MenuItem::action("Item 1"),
            MenuItem::submenu("Submenu", vec![MenuItem::action("Sub 1")]),
        ];

        let menu = Menu::new().with_items(items);
        assert!(!menu.is_submenu(0));
        assert!(menu.is_submenu(1));
    }

    #[test]
    fn test_menu_get_submenu() {
        let submenu_items = vec![MenuItem::action("Sub 1")];
        let items = vec![MenuItem::submenu("File", submenu_items)];

        let menu = Menu::new().with_items(items);
        let submenu = menu.get_submenu(0);
        assert!(submenu.is_some());
        assert_eq!(submenu.unwrap().len(), 1);
    }

    #[test]
    fn test_menu_render() {
        let items = vec![
            MenuItem::action("Item 1").with_shortcut("Ctrl+1"),
            MenuItem::action("Item 2"),
        ];

        let mut menu = Menu::new().with_items(items);
        menu.show();
        menu.set_position(5, 5);

        let backend = TestBackend::new(40, 10);
        let mut terminal = Terminal::new(backend).unwrap();

        terminal
            .draw(|f| {
                menu.render(f.area(), f.buffer_mut());
            })
            .unwrap();
    }
}