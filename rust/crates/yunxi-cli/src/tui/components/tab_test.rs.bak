#[cfg(test)]
mod tests {
    use super::*;
    use crate::tui::components::*;
    use crate::tui::core::action::Action;
    use crate::tui::core::action::ActionResult;
    use crate::tui::core::event::{Event, InputEvent};
    use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};
    use ratatui::backend::TestBackend;
    use ratatui::Terminal;

    #[test]
    fn test_tab_creation() {
        let tab = Tab::new();
        assert!(!tab.get_state().disabled);
        assert!(!tab.get_state().focused);
        assert_eq!(tab.get_state().id.starts_with("tab_"), true);
    }

    #[test]
    fn test_tab_with_items() {
        let tabs = vec![
            TabItem {
                label: "Tab 1".to_string(),
                content: "Content 1".to_string(),
                action: Some(Action::Navigate("/tab1".to_string())),
                disabled: false,
                closable: true,
            },
            TabItem {
                label: "Tab 2".to_string(),
                content: "Content 2".to_string(),
                action: Some(Action::Navigate("/tab2".to_string())),
                disabled: false,
                closable: true,
            },
        ];

        let tab = Tab::new().with_tabs(tabs);
        assert_eq!(tab.get_active_tab().unwrap().label, "Tab 1");
    }

    #[test]
    fn test_tab_navigation() {
        let tabs = vec![
            TabItem {
                label: "Tab 1".to_string(),
                content: "Content 1".to_string(),
                action: None,
                disabled: false,
                closable: true,
            },
            TabItem {
                label: "Tab 2".to_string(),
                content: "Content 2".to_string(),
                action: None,
                disabled: false,
                closable: true,
            },
        ];

        let mut tab = Tab::new().with_tabs(tabs);
        tab.next_tab();
        assert_eq!(tab.get_active_tab().unwrap().label, "Tab 2");

        tab.prev_tab();
        assert_eq!(tab.get_active_tab().unwrap().label, "Tab 1");
    }

    #[test]
    fn test_tab_pin() {
        let tabs = vec![TabItem {
            label: "Tab 1".to_string(),
            content: "Content 1".to_string(),
            action: None,
            disabled: false,
            closable: true,
        }];

        let mut tab = Tab::new().with_tabs(tabs);
        assert!(!tab.is_pinned(0));

        tab.pin_tab(0);
        assert!(tab.is_pinned(0));

        tab.toggle_pin(0);
        assert!(!tab.is_pinned(0));
    }

    #[test]
    fn test_tab_close() {
        let tabs = vec![
            TabItem {
                label: "Tab 1".to_string(),
                content: "Content 1".to_string(),
                action: None,
                disabled: false,
                closable: true,
            },
            TabItem {
                label: "Tab 2".to_string(),
                content: "Content 2".to_string(),
                action: None,
                disabled: false,
                closable: true,
            },
        ];

        let mut tab = Tab::new().with_tabs(tabs);
        assert!(tab.remove_tab(0).is_some());
        assert_eq!(tab.get_active_tab().unwrap().label, "Tab 2");
    }

    #[test]
    fn test_tab_cannot_close_pinned() {
        let tabs = vec![TabItem {
            label: "Tab 1".to_string(),
            content: "Content 1".to_string(),
            action: None,
            disabled: false,
            closable: true,
        }];

        let mut tab = Tab::new().with_tabs(tabs);
        tab.pin_tab(0);
        assert!(tab.remove_tab(0).is_none());
    }

    #[test]
    fn test_tab_render() {
        let tabs = vec![TabItem {
            label: "Tab 1".to_string(),
            content: "Content 1".to_string(),
            action: None,
            disabled: false,
            closable: true,
        }];

        let tab = Tab::new().with_tabs(tabs);
        let backend = TestBackend::new(40, 5);
        let mut terminal = Terminal::new(backend).unwrap();

        terminal
            .draw(|f| {
                tab.render(f.area(), f.buffer_mut());
            })
            .unwrap();
    }
}