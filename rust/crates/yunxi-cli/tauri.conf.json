{
  "productName": "云熙智能体",
  "version": "0.1.0",
  "identifier": "ai.yunxi.desktop",
  "mainBinaryName": "yunxi-desktop",
  "build": {
    "frontendDist": "./dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop",
    "features": ["desktop"]
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; style-src * 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "云熙智能体-专利代理人的智能助手",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "url": "index.html",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
