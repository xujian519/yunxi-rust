{
  "productName": "云熙智能体",
  "version": "0.1.0",
  "identifier": "ai.yunxi.desktop",
  "build": {
    "frontendDist": "./dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; style-src * 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "云熙智能体-专利代理人的智能助手",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
